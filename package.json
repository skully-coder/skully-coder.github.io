{
  "name": "abhinav-portfolio",
  "version": "1.0.0",
  "description": "Abhinav Agrawal's Portfolio",
  "source": "src/index.html",
  "homepage": "https://skully-coder.github.io/",
  "scripts": {
    "start": "parcel --no-cache",
    "build": "parcel build --no-cache",
    "clean-dist": "node scripts/clean-dist.mjs",
    "build-gh": "npm run clean-dist && parcel build --no-cache --public-url / --dist-dir deploy-dist && node scripts/prepare-dist-extras.mjs && node scripts/prune-dist.mjs",
    "check:sources": "node scripts/check-public-signals.mjs",
    "prune-dist": "node scripts/prune-dist.mjs",
    "verify:a11y": "node scripts/verify-accessibility.mjs",
    "verify:budget": "node scripts/verify-performance-budget.mjs",
    "verify": "node scripts/verify-portfolio.mjs",
    "verify:ui": "node scripts/verify-ui-strategy.mjs",
    "verify:http": "node scripts/smoke-deploy-http.mjs",
    "verify:all": "npm run check:sources && eslint src && npm run verify:ui && npm run verify:a11y && npm run build-gh && npm run verify && npm run verify:http && npm run verify:budget && npm run verify:a11y && npm run verify:ui",
    "predeploy": "npm run build-gh",
    "deploy": "gh-pages -d deploy-dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skully-coder/skully-coder.github.io.git"
  },
  "author": "Abhinav Agrawal",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/skully-coder/skully-coder.github.io/issues"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.31.7",
    "gh-pages": "^4.0.0",
    "html-webpack-plugin": "^5.5.0",
    "parcel": "^2.7.0",
    "prettier": "^2.7.1",
    "process": "^0.11.10"
  }
}
